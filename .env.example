# ── HotelWatch Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values.
# On Railway/Render, set these as environment variables in the dashboard.

# ── App ───────────────────────────────────────────────────────────────────────
APP_BASE_URL=https://your-app.railway.app   # Your deployed URL (no trailing slash)

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, works out of the box — fine for hundreds of users)
DATABASE_URL=sqlite:///./hotelwatch.db

# PostgreSQL (recommended for production on Railway)
# DATABASE_URL=postgresql://user:password@host:5432/hotelwatch

# ── Microsoft OAuth (for Outlook email connection) ────────────────────────────
# Register an app at https://portal.azure.com → Azure Active Directory → App registrations
# Add redirect URI: https://your-app.railway.app/auth/microsoft/callback
# Required permissions: Mail.Read, offline_access
MS_CLIENT_ID=your-azure-app-client-id
MS_CLIENT_SECRET=your-azure-app-client-secret
MS_TENANT_ID=common    # Use "common" for personal + work accounts

# ── Claude AI (for smart email parsing and page parsing fallback) ─────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Email Alerts (SMTP) ───────────────────────────────────────────────────────
# For Gmail: enable "App Passwords" in your Google account settings
# For Outlook: use smtp.office365.com / port 587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=HotelWatch <your@gmail.com>
